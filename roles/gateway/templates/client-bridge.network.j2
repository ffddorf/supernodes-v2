[Match]
Name=br0

[Link]
RequiredForOnline=no

[Network]
{% for addr in client_bridge_interface.ip_addresses %}
Address={{ addr.address }}
{% endfor %}
DHCPServer=yes
IPv6SendRA=yes

[DHCPServer]
PoolOffset={{ dhcp_pool_offset }}
PoolSize={{ dhcp_pool_size }}
EmitDNS=yes
ServerAddress={{
  client_bridge_interface.ip_addresses |
  map(attribute='address') |
  ansible.utils.ipv4 |
  first
}}
DNS={{ anycast_ipv4_service_address | ansible.utils.ipaddr('address') }}

[IPv6SendRA]
DNS={{ anycast_ipv6_service_address | ansible.utils.ipaddr('address') }}

{% for addr in client_bridge_interface.ip_addresses | map(attribute='address') | ansible.utils.ipv6 %}
[IPv6Prefix]
Prefix={{ addr | ansible.utils.ipaddr('network/prefix') }}
{% endfor %}
